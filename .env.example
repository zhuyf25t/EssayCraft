# DeepSeek API configuration. Copy to .env.local and fill locally.
# Never commit .env.local.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_FAST_MODEL=deepseek-v4-flash
DEEPSEEK_HIGH_QUALITY_MODEL=deepseek-v4-pro
# Set to 1 for deterministic local demos and tests even when .env.local has a key.
ESSAYCRAFT_FORCE_MOCK_AI=0
