# DeepSeek API configuration. Copy to .env.local and fill locally.
# Never commit .env.local.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_FAST_MODEL=deepseek-v4-flash
DEEPSEEK_HIGH_QUALITY_MODEL=deepseek-v4-pro
# Optional task-specific provider waits before local fallback.
ESSAYCRAFT_ASSIST_TIMEOUT_MS=12000
ESSAYCRAFT_REFRESH_TIMEOUT_MS=10000
ESSAYCRAFT_TRANSLATE_TIMEOUT_MS=10000
ESSAYCRAFT_GENERATE_TIMEOUT_MS=30000
# Optional legacy/dev quick fallback setting for diagnostics and local experiments.
ESSAYCRAFT_FAST_FALLBACK_MS=2500
# Set to 1 for deterministic local demos and tests even when .env.local has a key.
ESSAYCRAFT_FORCE_MOCK_AI=0
