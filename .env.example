# DeepSeek API configuration. Copy to .env.local and fill locally.
# Never commit .env.local.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FAST_MODEL=deepseek-v4-pro
DEEPSEEK_HIGH_QUALITY_MODEL=deepseek-v4-pro
# Provider-first task timeouts. Timeout means AI unavailable unless mock is explicitly forced.
ESSAYCRAFT_CHAT_TIMEOUT_MS=60000
ESSAYCRAFT_EDIT_TIMEOUT_MS=60000
ESSAYCRAFT_REFRESH_TIMEOUT_MS=60000
ESSAYCRAFT_TRANSLATE_TIMEOUT_MS=60000
ESSAYCRAFT_GENERATE_TIMEOUT_MS=90000
ESSAYCRAFT_GENERATE_MAX_TOKENS=16384
# Optional: override Next's build cache directory for isolated test servers.
# Leave unset for normal npm run dev/build/start.
NEXT_DIST_DIR=
# Set to 1 for deterministic local demos and tests even when .env.local has a key.
ESSAYCRAFT_FORCE_MOCK_AI=0
# Optional dev-only switch documented by diagnostics. Product routes do not use mock unless FORCE_MOCK is 1.
ESSAYCRAFT_ALLOW_OFFLINE_MOCK=0
